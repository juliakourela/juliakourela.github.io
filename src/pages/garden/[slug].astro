---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('garden');
  return notes.map(note => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
---
<BaseLayout title={note.data.title} description={note.data.description}>
  <article>
    <h1 class="post-title">{note.data.title}</h1>
    <div class="post-meta">
      <span class={`stage ${note.data.stage}`}>{note.data.stage}</span>
      <span>
        Last updated{' '}
        <time datetime={note.data.updated.toISOString()}>
          {note.data.updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </span>
    </div>
    <Content />
  </article>
</BaseLayout>
