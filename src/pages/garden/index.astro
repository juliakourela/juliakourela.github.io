---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('garden'))
  .sort((a, b) => b.data.updated.valueOf() - a.data.updated.valueOf());
---
<BaseLayout title="Garden" description="A digital garden by Jules Kourelakos.">
  <div class="page-header">
    <h1>Digital Garden</h1>
    <p>
      Assorted notes in various stages of completeness.
    </p>
  </div>

  {notes.length === 0 ? (
    <p style="color: var(--muted)">Nothing planted yet.</p>
  ) : (
    <ul class="post-list">
      {notes.map(note => (
        <li>
          <a href={`/garden/${note.slug}`}>{note.data.title}</a>
          <span class="post-meta-inline">
            <span class={`stage ${note.data.stage}`}>{note.data.stage}</span>
            {note.data.updated.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </span>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
